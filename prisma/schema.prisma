generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// TABLA PADRE ITEM (CAMPOS COMUNES)
model Item {
  id                  Int                   @id @default(autoincrement())
  name                String                
  imageUrl            String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  ItemTranslation     ItemTranslation[]
}

//TABLA HIJA DE TRADUCCIONES PARA ITEMS
model ItemTranslation {
  id                  Int                   @id @default(autoincrement())
  itemId              Int                   
  lang                String
  name                String
  description         String
  rarity              String
  item                Item                  @relation(fields: [itemId], references: [id], onDelete: Cascade)

    @@unique([itemId, lang])
}

//TABLA PADRE MOBS (CAMPOS COMUNES)
model Mob {
  id                  Int                   @id @default(autoincrement())
  name                String                
  health              Int   
  imageUrl            String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  MobTranslation      MobTranslation[]
}

//TABLA HIJA DE TRADUCCIONES PARA MOBS 
model MobTranslation {
  id                  Int                   @id @default(autoincrement())
  mobId               Int 
  lang                String
  name                String
  description         String
  type                String
  mob                 Mob                   @relation(fields: [mobId], references: [id], onDelete: Cascade)

    @@unique([mobId, lang])
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  role      String     @default("CLIENT") 
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  favorites Favorite[]   // relacion: Un usuario puede tener muchos favoritos
}

model Favorite {
  id        Int      @id @default(autoincrement())
  // relacion con el Usuario que guarda el favorito
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId  Int      // relacion con la entidad guardada 
  entityType String  // item o mob
  
  createdAt DateTime @default(now())
  @@unique([userId, entityId, entityType])  // usuario no puede guardar la misma entidad dos veces
}