generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Item {
  id          Int      @id @default(autoincrement()) 
  name        String
  description String
  rarity      String
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Mob {
  id          Int      @id @default(autoincrement()) 
  name        String
  description String
  health      Int 
  type        String  
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}